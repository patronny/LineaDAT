{
  "name": "lineadat-keeper",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted cron keeper for the on-chainDAT bot (testnet: LINEASTR on Base Sepolia). Runs on Fly.io. Replaces unreliable GitHub Actions cron + deprecated Gelato W3F.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "tick": "tsx src/index.ts --once"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
